# Copy this file to deploy\.env and edit values for the target machine.
# Values in deploy\.env override the project root .env.local when start-all.cmd runs.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=deepinsight
DB_USER=root
DB_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

SERVER_PORT=8080
FRONTEND_PORT=5173

# Optional local paths. Leave blank when java.exe and redis-server.exe are already on PATH.
DEEPINSIGHT_JAVA_HOME=
REDIS_EXE=
REDIS_SKIP_START=0

JWT_SECRET=
JWT_EXPIRATION=86400000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
