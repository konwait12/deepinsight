# DeepInsight safe example environment.
# Copy to .env.local for local development or .env for deployment.
# Never commit real secrets.

VITE_API_BASE_URL=/api/v1

DB_HOST=localhost
DB_PORT=3306
DB_NAME=deepinsight
DB_USER=root
DB_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Generate a strong Base64 secret before running auth-protected endpoints.
# PowerShell example:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=
JWT_EXPIRATION=86400000

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
SERVER_PORT=8080

# Optional: JDK path used by scripts/start-backend.ps1.
DEEPINSIGHT_JAVA_HOME=D:\jdk\java21
